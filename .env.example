# Source installs may copy this file to .env. The Windows client writes its own
# per-user configuration under %LOCALAPPDATA%\MaterialAIWorkbench\config.
MATERIALAI_WORKSPACE_ROOT=./workspace

# Optional OpenAI-compatible language-model service. Leave blank to use the
# built-in rule parser without network access.
MATERIALAI_LLM_PROVIDER=custom
MATERIALAI_LLM_BASE_URL=
MATERIALAI_LLM_MODEL=
MATERIALAI_LLM_API_KEY_ENV=MATERIALAI_LLM_API_KEY
MATERIALAI_LLM_REQUIRE_API_KEY=true
MATERIALAI_LLM_API_KEY=

# Optional Abaqus installation and live MCP bridge. Uncomment and edit the
# executable paths for the local Abaqus version.
# MATERIALAI_ABAQUS_BAT=C:/SIMULIA/Commands/abaqus.bat
# MATERIALAI_ABAQUS_SMAPYTHON=C:/SIMULIA/EstProducts/win_b64/code/bin/SMAPython.exe
MATERIALAI_ABAQUS_MCP_HOST=127.0.0.1
MATERIALAI_ABAQUS_MCP_PORT=48152
