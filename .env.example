# Copy this file to .env and keep the real .env local.
MATERIALAI_WORKSPACE_ROOT=./workspace

# Optional OpenAI-compatible LLM provider.
MATERIALAI_LLM_PROVIDER=deepseek
MATERIALAI_LLM_BASE_URL=https://api.deepseek.com/v1
MATERIALAI_LLM_MODEL=deepseek-chat
MATERIALAI_LLM_API_KEY_ENV=DEEPSEEK_API_KEY
MATERIALAI_LLM_REQUIRE_API_KEY=true
DEEPSEEK_API_KEY=

# Optional Abaqus installation and live MCP bridge.
MATERIALAI_ABAQUS_ROOT=D:/ABAQUS/2023
MATERIALAI_ABAQUS_MCP_HOST=127.0.0.1
MATERIALAI_ABAQUS_MCP_PORT=48152
