{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/hwu12sluedu/MaterialAI-Workbench/schemas/case_package.schema.json",
  "title": "MaterialAI Abaqus Case Package",
  "description": "Versioned, portable metadata contract for an indexed Abaqus simulation case.",
  "type": "object",
  "required": [
    "schema_version",
    "package_type",
    "case_id",
    "title",
    "source",
    "solver",
    "units",
    "model",
    "results",
    "files",
    "provenance",
    "quality"
  ],
  "properties": {
    "schema_version": {"const": "2.0"},
    "package_type": {"const": "materialai_abaqus_case"},
    "case_id": {"type": "string", "minLength": 1},
    "title": {"type": "string", "minLength": 1},
    "description": {"type": "string"},
    "tags": {"type": "array", "items": {"type": "string"}},
    "user_status": {"type": "string"},
    "created_at": {"type": "string"},
    "updated_at": {"type": "string"},
    "source": {
      "type": "object",
      "required": ["mode", "root", "fingerprint", "file_count", "total_size_bytes"],
      "properties": {
        "mode": {"type": "string", "enum": ["reference", "copy", "generated", "uploaded"]},
        "root": {"type": "string"},
        "fingerprint": {"type": "string"},
        "file_count": {"type": "integer", "minimum": 0},
        "total_size_bytes": {"type": "integer", "minimum": 0}
      },
      "additionalProperties": true
    },
    "solver": {
      "type": "object",
      "required": ["name", "execution_state", "job_names"],
      "properties": {
        "name": {"const": "Abaqus"},
        "version": {"type": "string"},
        "execution_state": {
          "type": "string",
          "enum": [
            "unknown",
            "prepared",
            "failed",
            "completed_without_odb",
            "odb_present_unverified",
            "solved",
            "postprocessed"
          ]
        },
        "job_names": {"type": "array", "items": {"type": "string"}, "uniqueItems": true}
      },
      "additionalProperties": true
    },
    "units": {
      "type": "object",
      "required": ["system", "length", "force", "time", "stress", "temperature", "declared"],
      "properties": {
        "system": {"type": "string"},
        "length": {"type": "string"},
        "force": {"type": "string"},
        "time": {"type": "string"},
        "stress": {"type": "string"},
        "temperature": {"type": "string"},
        "declared": {"type": "boolean"}
      },
      "additionalProperties": true
    },
    "model": {
      "type": "object",
      "required": ["inp", "material_type", "geometry", "loading", "mesh", "parameters"],
      "additionalProperties": true
    },
    "results": {
      "type": "object",
      "required": ["indexed", "abaqus", "odb_features", "odb_extractions", "odb_frame_series", "labels"],
      "properties": {
        "labels": {
          "type": "object",
          "additionalProperties": {"type": "number"}
        }
      },
      "additionalProperties": true
    },
    "files": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "relative_path",
          "name",
          "extension",
          "category",
          "size_bytes",
          "modified_at",
          "fingerprint",
          "fingerprint_mode"
        ],
        "properties": {
          "relative_path": {"type": "string"},
          "name": {"type": "string"},
          "extension": {"type": "string"},
          "category": {"type": "string"},
          "size_bytes": {"type": "integer", "minimum": 0},
          "modified_at": {"type": "string"},
          "fingerprint": {"type": "string"},
          "fingerprint_mode": {
            "type": "string",
            "enum": ["sha256-full", "sha256-size-first-last-1MiB", "unavailable", ""]
          }
        },
        "additionalProperties": true
      }
    },
    "provenance": {"type": "object"},
    "quality": {"$ref": "#/$defs/quality"}
  },
  "$defs": {
    "quality": {
      "type": "object",
      "required": [
        "schema_version",
        "checked_at",
        "status",
        "score",
        "execution_state",
        "training_eligible",
        "blocking_reasons",
        "recommended_actions",
        "checks"
      ],
      "properties": {
        "schema_version": {"const": "1.0"},
        "checked_at": {"type": "string"},
        "status": {"type": "string", "enum": ["pass", "warn", "fail"]},
        "score": {"type": "integer", "minimum": 0, "maximum": 100},
        "execution_state": {"type": "string"},
        "training_eligible": {"type": "boolean"},
        "blocking_reasons": {"type": "array", "items": {"type": "string"}, "uniqueItems": true},
        "recommended_actions": {"type": "array", "items": {"type": "string"}},
        "checks": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["id", "status", "weight", "message", "evidence"],
            "properties": {
              "id": {"type": "string"},
              "status": {"type": "string", "enum": ["pass", "warn", "fail"]},
              "weight": {"type": "integer", "minimum": 0},
              "message": {"type": "string"},
              "evidence": {"type": "object"}
            },
            "additionalProperties": false
          }
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
